<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/logo_SS.png">
    <title>CompusHub | Student Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Smooth transition for the chat window */
        .chat-window {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateY(20px) scale(0.95);
            opacity: 0;
            pointer-events: none;
        }
        .chat-window.active {
            transform: translateY(0) scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        /* Custom scrollbar for dark theme */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4B5563; }
    </style>
</head>
<body class="bg-gray-900 min-h-screen font-sans flex flex-col relative text-gray-200">

    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center space-x-8">
                    <a href="/" class="flex-shrink-0 flex items-center gap-3 text-xl font-bold text-white">
                        <div class="bg-blue-600 p-2 rounded-lg">
                            <i class="fa-solid fa-graduation-cap text-white"></i>
                        </div>
                        CompusHub
                    </a>
                    <div class="hidden md:flex space-x-2">
                        <a href="#dashboard" class="text-white bg-gray-900 px-3 py-2 rounded-md text-sm font-medium border border-gray-700 transition">Dashboard</a>
                        <a href="#faculty" class="text-gray-300 hover:text-white hover:bg-gray-700 px-3 py-2 rounded-md text-sm font-medium transition">Faculty</a>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="hidden sm:flex flex-col items-end">
                        <span class="text-sm font-medium text-white"><%= user ? user.lastName + ' ' + user.firstName : 'Student' %></span>
                        <span class="text-xs text-blue-400">ID: <%= user && user.nationalId ? user.nationalId : 'N/A' %></span>
                    </div>
                    <img class="h-10 w-10 rounded-full border-2 border-gray-600 object-cover" 
src="<%= user && user.profilePicture ?  user.profilePicture : '/default-avatar.png' %>"
                         alt="Profile Picture">
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8 w-full">
        
        <header id="dashboard">
            <h1 class="text-3xl font-bold text-white">Welcome, <%= user ? user.firstName : 'Student' %> 👋</h1>
            <p class="text-gray-400 mt-2">Manage your absences and administrative documents from your personal space.</p>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <a href="/api/absence" class="bg-gray-800 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 border border-gray-700 hover:border-blue-500 flex items-start gap-5 cursor-pointer group">
                <div class="bg-gray-900 border border-gray-700 p-4 rounded-lg text-red-400 group-hover:bg-red-500 group-hover:text-white transition-colors">
                    <i class="fa-solid fa-calendar-xmark text-2xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-semibold text-white group-hover:text-blue-400 transition-colors">Absence Tracking</h2>
                    <p class="text-sm text-gray-400 mt-2">Check the total number of your absences per module and monitor your attendance.</p>
                </div>
            </a>

            <a href="api/attestations" class="bg-gray-800 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 border border-gray-700 hover:border-blue-500 flex items-start gap-5 cursor-pointer group">
                <div class="bg-gray-900 border border-gray-700 p-4 rounded-lg text-green-400 group-hover:bg-green-500 group-hover:text-white transition-colors">
                    <i class="fa-solid fa-file-signature text-2xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-semibold text-white group-hover:text-blue-400 transition-colors">Certificate of Attendance</h2>
                    <p class="text-sm text-gray-400 mt-2">Generate and download your official certificate of attendance in PDF format.</p>
                </div>
            </a>
        </section>

        <section id="faculty" class="bg-gray-800 rounded-xl shadow-lg border border-gray-700 p-8 mt-8">
            <div class="flex items-center gap-3 mb-6">
                <i class="fa-solid fa-building-columns text-blue-500 text-2xl"></i>
                <h2 class="text-2xl font-bold text-white">About the Faculty</h2>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
                <div class="space-y-4 text-gray-300 text-sm leading-relaxed">
                    <p>Welcome to the Faculty of Science and Technology. We are committed to providing excellent education, fostering innovation, and preparing our students for the challenges of tomorrow.</p>
                    
                    <div class="bg-gray-900 p-4 rounded-lg border border-gray-700 mt-4">
                        <p><strong class="text-white">Campus Hours:</strong> Monday - Friday, 8:00 AM - 6:00 PM</p>
                        <p class="mt-2"><strong class="text-white">Administration Office:</strong> Block A, Room 101</p>
                    </div>

                    <ul class="space-y-2 mt-4">
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-blue-500"></i> State-of-the-art laboratories</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-blue-500"></i> Extensive library resources</li>
                        <li class="flex items-center gap-2"><i class="fa-solid fa-check text-blue-500"></i> Active student clubs</li>
                    </ul>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80" alt="Campus" class="rounded-lg shadow-md object-cover h-48 w-full border border-gray-600 hover:opacity-80 transition">
                    <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80" alt="Students" class="rounded-lg shadow-md object-cover h-48 w-full border border-gray-600 hover:opacity-80 transition">
                </div>
            </div>
        </section>
    </main>

    <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
        
        <div id="ai-chat-window" class="chat-window bg-gray-800 w-80 sm:w-96 rounded-2xl shadow-2xl border border-gray-600 mb-4 overflow-hidden flex flex-col h-[450px]">
            <div class="bg-blue-600 p-4 flex justify-between items-center shadow-md z-10">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <div class="bg-white text-blue-600 rounded-full h-10 w-10 flex items-center justify-center text-xl">
                            <i class="fa-solid fa-robot"></i>
                        </div>
                        <div class="absolute bottom-0 right-0 h-3 w-3 bg-green-400 border-2 border-blue-600 rounded-full"></div>
                    </div>
                    <div>
                        <span class="block font-bold text-white text-sm">AI Assistant</span>
                        <span class="block text-blue-200 text-xs">Online</span>
                    </div>
                </div>
                <button id="close-chat" class="text-white hover:text-gray-200 focus:outline-none transition-transform hover:rotate-90">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            
            <div class="flex-grow p-4 overflow-y-auto bg-gray-900 flex flex-col gap-4" id="chat-messages">
                <div class="flex items-end gap-2">
                    <div class="bg-blue-600 text-white rounded-2xl rounded-bl-sm p-3 text-sm max-w-[85%] shadow-sm">
                        Hello <%= user ? user.firstName : 'there' %>! 👋 I'm your virtual assistant. How can I help you today? 
                    </div>
                </div>
            </div>
            

            <div class="p-3 bg-gray-800 border-t border-gray-700 flex items-center gap-2">
                <input type="text" id="chat-input" placeholder="Type your message..." class="flex-grow bg-gray-900 border border-gray-700 text-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-full px-4 py-2.5 text-sm outline-none transition-all placeholder-gray-500">
                
                <button id="send-message-btn" class="bg-blue-600 text-white rounded-full h-10 w-10 flex items-center justify-center hover:bg-blue-700 transition flex-shrink-0 shadow-md">
                    <i class="fa-solid fa-paper-plane text-sm"></i>
                </button>
            </div>
        </div>

        <button id="toggle-chat" class="bg-blue-600 hover:bg-blue-700 text-white rounded-full h-16 w-16 shadow-[0_0_15px_rgba(37,99,235,0.5)] flex items-center justify-center transition-all duration-300 hover:scale-110 focus:outline-none relative">
            <i class="fa-solid fa-comment-dots text-3xl"></i>
            <span class="absolute top-0 right-0 flex h-4 w-4">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500 border-2 border-gray-900"></span>
            </span>
        </button>
    </div>

<script>
    const chatWindow = document.getElementById('ai-chat-window');
    const toggleBtn = document.getElementById('toggle-chat');
    const closeBtn = document.getElementById('close-chat');
    const notificationPing = toggleBtn.querySelector('.absolute.top-0');

    function toggleChat() {
        chatWindow.classList.toggle('active');
        if (notificationPing) notificationPing.style.display = 'none';
    }

    toggleBtn.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    // --- CHAT LOGIC ---

    const chatInput = document.getElementById('chat-input');
    const sendBtn = document.getElementById('send-message-btn');
    const chatMessagesContainer = document.getElementById('chat-messages');

    // Get the student ID from EJS
    const studentId = "<%= user && user._id ? user._id : '' %>"; 

    // Function to scroll to the bottom of the chat
    function scrollToBottom() {
        chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
    }

    // Render User Message
    function appendUserMessage(text) {
        const msgHTML = `
        <div class="flex items-end gap-2 justify-end mt-4">
            <div class="bg-gray-700 text-white rounded-2xl rounded-br-sm p-3 text-sm max-w-[85%] shadow-sm">
                ${text}
            </div>
        </div>`;
        chatMessagesContainer.insertAdjacentHTML('beforeend', msgHTML);
        scrollToBottom();
    }

    // Render AI Message
    function appendAIMessage(text) {
        // Simple replace to convert newlines (\n) to <br> tags for HTML
        const formattedText = text.replace(/\n/g, '<br>');
        const msgHTML = `
        <div class="flex items-end gap-2 mt-4">
            <div class="bg-blue-600 text-white rounded-2xl rounded-bl-sm p-3 text-sm max-w-[85%] shadow-sm">
                ${formattedText}
            </div>
        </div>`;
        chatMessagesContainer.insertAdjacentHTML('beforeend', msgHTML);
        scrollToBottom();
    }

    // Show "Working on your request" loader
    function showLoader() {
        const loaderHTML = `
        <div id="ai-loader" class="flex items-end gap-2 mt-4">
            <div class="bg-blue-600 text-white rounded-2xl rounded-bl-sm p-3 text-sm shadow-sm flex items-center gap-2 opacity-80">
                <i class="fa-solid fa-spinner fa-spin text-xs"></i>
                <span class="animate-pulse">Working on your request...</span>
            </div>
        </div>`;
        chatMessagesContainer.insertAdjacentHTML('beforeend', loaderHTML);
        scrollToBottom();
    }

    // Remove the loader
    function removeLoader() {
        const loader = document.getElementById('ai-loader');
        if (loader) loader.remove();
    }

    // Handle sending the message
    async function handleSendMessage() {
        const messageText = chatInput.value.trim();
        if (!messageText) return;

        // 1. Show user message and clear input
        appendUserMessage(messageText);
        chatInput.value = '';

        // 2. Show loader
        showLoader();

        try {
            // 3. Send to your Express backend route
            const response = await fetch('/api/assistantAgent/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    message: messageText,
                    student_id: studentId
                })
            });

            const data = await response.json();
            
            // 4. Remove loader and show AI response
            removeLoader();
            
            if (data.response) {
                appendAIMessage(data.response);
            } else {
                appendAIMessage("Received an unexpected format from the server.");
            }

        } catch (error) {
            console.error('Chat Error:', error);
            removeLoader();
            appendAIMessage("Sorry, I'm having trouble connecting to the server right now. Please try again later.");
        }
    }

    // Event listeners for clicking Send or pressing Enter
    sendBtn.addEventListener('click', handleSendMessage);
    chatInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            handleSendMessage();
        }
    });
</script>
</body>
</html>