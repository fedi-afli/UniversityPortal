<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CampusHub | Attendance Certificate</title>
    <link rel="icon" type="image/png" href="/logo_SS.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Smooth transition for the chat window */
    .chat-window {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateY(20px) scale(0.95);
        opacity: 0;
        pointer-events: none;
    }
    .chat-window.active {
        transform: translateY(0) scale(1);
        opacity: 1;
        pointer-events: auto;
    }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4B5563; }
    </style>
</head>
<body class="bg-gray-900 min-h-screen font-sans flex flex-col text-gray-200">

    <%- include('partials/navbar') %>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8 w-full">

        <header>
            <div class="flex items-center gap-2 text-sm text-gray-400 mb-2">
                <a href="/" class="hover:text-blue-400 transition">Home</a>
                <i class="fa-solid fa-chevron-right text-xs"></i>
                <span class="text-gray-200">Attendance Certificate</span>
            </div>
            <h1 class="text-3xl font-bold text-white">Attendance Certificate</h1>
        </header>

        <!-- Student info card -->
        <section class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-lg flex items-center gap-5">
            <img
                src="<%= etudiant.profilePicture %>"
                alt="Profile"
                class="w-16 h-16 rounded-full object-cover border-2 border-blue-600/50 shadow-md flex-shrink-0"
            >
            <div>
                <p class="text-base font-semibold text-white"><%= etudiant.prenom %> <%= etudiant.nom %></p>
                <p class="text-sm text-gray-400 mt-0.5">
                    National ID:
                    <span class="font-mono text-blue-400"><%= etudiant.cin || etudiant.nationalId || '—' %></span>
                </p>
            </div>
        </section>

        <section class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg overflow-hidden">

            <div class="p-6 border-b border-gray-700">
                <h2 class="text-lg font-semibold text-white">Certificate Details</h2>
                <p class="text-sm text-gray-400 mt-1">Select the academic year and semester, then generate your certificate.</p>
            </div>

            <div class="p-6 space-y-6">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label for="anneeInput" class="block text-xs font-medium text-gray-300 uppercase tracking-wide mb-1.5">
                            <i class="fa-solid fa-calendar-days text-blue-400 mr-1"></i> Academic Year
                        </label>
                        <input
                            type="text"
                            id="anneeInput"
                            value="2023-2024"
                            class="w-full px-4 py-2.5 bg-gray-900 border border-gray-600 rounded-lg text-white placeholder-gray-500 focus:border-blue-500 focus:ring-1 focus:ring-blue-500/30 transition-all duration-200 text-sm"
                        >
                    </div>

                    <div>
                        <label for="semestreInput" class="block text-xs font-medium text-gray-300 uppercase tracking-wide mb-1.5">
                            <i class="fa-solid fa-layer-group text-blue-400 mr-1"></i> Semester
                        </label>
                        <div class="relative">
                            <select
                                id="semestreInput"
                                class="w-full px-4 py-2.5 bg-gray-900 border border-gray-600 rounded-lg text-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500/30 transition-all duration-200 text-sm appearance-none"
                            >
                                <option value="S1">Semester 1</option>
                                <option value="S2">Semester 2</option>
                                <option value="Annual">Annual</option>
                            </select>
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                <i class="fa-solid fa-chevron-down text-gray-400 text-xs"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <button
                    onclick="requestAttestation()"
                    class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-semibold py-2.5 px-6 rounded-lg transition-all duration-200 shadow-lg shadow-blue-900/20 text-sm"
                >
                    <i class="fa-solid fa-file-circle-check"></i>
                    Generate Certificate
                </button>

                <div id="download-area" class="hidden pt-4 border-t border-gray-700">
                    <a
                        id="download-link"
                        href="#"
                        target="_blank"
                        class="inline-flex items-center gap-2 bg-gray-700 hover:bg-gray-600 border border-gray-600 text-white font-semibold py-2.5 px-6 rounded-lg transition-all duration-200 text-sm"
                    >
                        <i class="fa-solid fa-download text-blue-400"></i>
                        Download PDF Certificate
                    </a>
                </div>
            </div>
        </section>

        <section class="bg-gray-800 rounded-xl p-5 border border-gray-700 shadow-lg flex items-start gap-4">
            <div class="h-10 w-10 rounded-full bg-blue-900/50 flex items-center justify-center border border-blue-800 flex-shrink-0 mt-0.5">
                <i class="fa-solid fa-envelope text-blue-400"></i>
            </div>
            <div>
                <p class="text-sm font-medium text-white">Email Notification</p>
                <p class="text-sm text-gray-400 mt-0.5">
                    You will be notified by email once your certificate is ready — or if there is any issue.
                </p>
                <p class="text-xs text-gray-500 mt-1">Processing usually takes a few moments.</p>
            </div>
        </section>

    </main>

    <script>
        const matriculeEtudiant = "<%= etudiant.nationalId || etudiant.studentId || '' %>";

        async function requestAttestation() {
            const logs = document.getElementById('system-logs') || { innerHTML: '', scrollTop: 0 };
            logs.innerHTML += `<div class="text-blue-400 text-sm mt-1">> Starting request... ⏳</div>`;

            document.getElementById('download-area').classList.add('hidden');

            if (logs.scrollTop) logs.scrollTop = logs.scrollHeight;

            const payload = {
                matricule: matriculeEtudiant,
                annee_universitaire: document.getElementById('anneeInput').value.trim(),
                semestre: document.getElementById('semestreInput').value,
                periodStart: "2023-09-01",
                periodEnd: "2024-01-31"
            };

            try {
                const res = await fetch('/api/attestations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                    credentials: 'include'
                });

                const data = await res.json();

                if (res.ok) {
                    logs.innerHTML += `<div class="text-emerald-400 text-sm mt-1">> Request processed successfully.</div>`;
                    if (data.requestId || data._id) {
                        document.getElementById('download-link').href = `/api/attestations/${data.requestId || data._id}/download`;
                        document.getElementById('download-area').classList.remove('hidden');
                    }
                } else {
                    logs.innerHTML += `<div class="text-red-400 text-sm mt-1">> Server error: ${data.error || 'Generation failed'}</div>`;
                }
            } catch (err) {
                logs.innerHTML += `<div class="text-red-400 text-sm mt-1">> Network error: ${err.message}</div>`;
            }

            if (logs.scrollTop) logs.scrollTop = logs.scrollHeight;
        }
    </script>
<div class="fixed bottom-6 right-6 z-50">
    <button id="toggle-chat"
            class="bg-blue-600 hover:bg-blue-700 text-white rounded-full h-16 w-16 shadow-[0_0_15px_rgba(37,99,235,0.5)] flex items-center justify-center transition-all duration-300 hover:scale-110 focus:outline-none relative">
        <i class="fa-solid fa-comment-dots text-3xl"></i>
        <span class="absolute top-0 right-0 flex h-4 w-4">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500 border-2 border-gray-900"></span>
        </span>
    </button>
</div>
<%- include('partials/chat-widget') %> 
<script>
    const chatWindow = document.getElementById('ai-chat-window');
    const toggleBtn  = document.getElementById('toggle-chat');
    const closeBtn   = document.getElementById('close-chat');
    const notificationPing = toggleBtn?.querySelector('.absolute.top-0');

    function toggleChat() {
        chatWindow.classList.toggle('active');
        if (notificationPing) notificationPing.style.display = 'none';
    }

    if (toggleBtn) toggleBtn.addEventListener('click', toggleChat);
    if (closeBtn)  closeBtn.addEventListener('click', toggleChat);

    document.addEventListener('click', function(e) {
        if (!chatWindow.contains(e.target) && !toggleBtn.contains(e.target)) {
            chatWindow.classList.remove('active');
        }
    });
</script>
</body>
</html>