<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portail Étudiant - Attestations IA</title>
    <link rel="icon" type="image/png" href="/logo_SS.png">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { darkbg: '#0d1117', cardbg: '#161b22' } } } }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #0d1117; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0d1117; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4 text-gray-200">

    <div class="w-full max-w-lg bg-cardbg p-6 md:p-8 rounded-xl shadow-2xl border border-gray-700">
        
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-white mb-2">Portail Étudiant</h1>
                <p class="text-sm text-gray-400">Demande d'Attestations de Présence (IA)</p>
            </div>
            <a href="/logout" class="text-sm text-red-400 hover:text-red-300 font-semibold px-3 py-1 border border-red-400/30 rounded hover:bg-red-400/10 transition">
                Déconnexion
            </a>
        </div>

        <div id="chatbot-section" class="space-y-5">
            
            <div class="p-4 bg-darkbg rounded-lg border border-gray-700 flex items-center space-x-4">
                <img src="<%= etudiant.profilePicture %>" alt="Profil" class="w-12 h-12 rounded-full border border-gray-600 object-cover">
                <div>
                    <p class="text-sm text-gray-400">Connecté(e) : <strong class="text-white"><%= etudiant.prenom %> <%= etudiant.nom %></strong></p>
                    <p class="text-sm text-gray-400">CIN : <span class="text-blue-400 font-mono"><%= etudiant.cin %></span></p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm text-gray-400 mb-1">Année univ.</label>
                    <input type="text" id="anneeInput" value="2023-2024" class="w-full px-4 py-2 rounded bg-darkbg text-white border border-gray-700 focus:outline-none focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm text-gray-400 mb-1">Semestre</label>
                    <select id="semestreInput" class="w-full px-4 py-2 rounded bg-darkbg text-white border border-gray-700 focus:outline-none focus:border-blue-500">
                        <option value="S1">Semestre 1</option>
                        <option value="S2">Semestre 2</option>
                        <option value="Annuel">Annuel</option>
                    </select>
                </div>
            </div>
            
            <button onclick="requestAttestation()" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-4 rounded transition duration-200 shadow-lg shadow-emerald-900/20">
                Générer Attestation (Ollama)
            </button>

            <div class="mt-4">
                <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Logs système</h3>
                <div id="system-logs" class="bg-darkbg p-3 rounded border border-gray-700 text-xs font-mono text-gray-400 h-32 overflow-y-auto space-y-1"></div>
            </div>

            <div id="download-area" class="hidden pt-2 border-t border-gray-700 text-center">
                <a id="download-link" href="#" target="_blank" class="inline-block w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 px-4 rounded transition shadow-lg shadow-indigo-900/20">
                    📥 Télécharger le PDF
                </a>
            </div>
        </div>

    </div>

    <script>
        // Le CIN est injecté ici de façon sécurisée depuis le serveur !
        const matriculeEtudiant = "<%= etudiant.cin %>"; 

        async function requestAttestation() {
            const logs = document.getElementById('system-logs');
            logs.innerHTML += `<div class="text-blue-400">> Démarrage de l'analyse (Ollama)... ⏳</div>`;
            document.getElementById('download-area').classList.add('hidden');
            logs.scrollTop = logs.scrollHeight;

            const payload = {
                matricule: matriculeEtudiant,
                annee_universitaire: document.getElementById('anneeInput').value,
                semestre: document.getElementById('semestreInput').value,
                periodStart: "2023-09-01", 
                periodEnd: "2024-01-31"
            };

            try {
                // IMPORTANT : Les cookies JWT gèrent la sécurité de la requête automatiquement
                const res = await fetch('/api/attestations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const data = await res.json();
                
                if(res.ok) {
                    logs.innerHTML += `<div class="text-green-400">> IA a traité la demande ! Statut : Terminé.</div>`;
                    if(data._id) {
                        document.getElementById('download-link').href = `/api/attestations/${data._id}/download`;
                        document.getElementById('download-area').classList.remove('hidden');
                    }
                } else {
                    logs.innerHTML += `<div class="text-red-400">> Erreur serveur : ${data.error || 'Échec de la génération'}</div>`;
                }

            } catch (err) {
                logs.innerHTML += `<div class="text-red-400">> Erreur réseau : ${err.message}</div>`;
            }
            logs.scrollTop = logs.scrollHeight;
        }
    </script>
</body>
</html>