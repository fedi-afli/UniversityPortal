<div id="ai-chat-window" class="chat-window fixed bottom-24 right-6 w-96 h-[500px] bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden z-50 flex flex-col">
    <!-- Header -->
    <div class="bg-gray-900 p-4 border-b border-gray-700 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <div class="bg-blue-600 p-2 rounded-lg">
                <i class="fa-solid fa-robot text-white"></i>
            </div>
            <div>
                <h3 class="text-white font-semibold">CampusHub Assistant</h3>
                <p class="text-xs text-gray-400">Ask anything about your studies</p>
            </div>
        </div>
        <button id="close-chat" class="text-gray-400 hover:text-white focus:outline-none">
            <i class="fa-solid fa-times text-xl"></i>
        </button>
    </div>

    <!-- Messages Area -->
    <div class="flex-1 p-4 overflow-y-auto bg-gray-900 space-y-4">
        <!-- Example messages – you can make this dynamic later -->
        <div class="flex items-start gap-3">
            <div class="bg-blue-600/20 p-3 rounded-lg max-w-[80%]">
                <p class="text-sm text-gray-200">Hello! How can I help you today?</p>
            </div>
        </div>
        <!-- More messages can be appended here via JS -->
    </div>

    <!-- Input Area -->
    <div class="p-4 border-t border-gray-700 bg-gray-800">
        <form id="chat-form" class="flex gap-2">
            <input type="text" id="chat-input" placeholder="Type your message..." 
                   class="flex-1 px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-blue-500">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 rounded-lg transition">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>