<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/logo_SS.png">
    <title>CampusHub | Absence Tracking</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Custom scrollbar for dark theme */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4B5563; }
    </style>
</head>
<body class="bg-gray-900 min-h-screen font-sans flex flex-col text-gray-200">

    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center space-x-8">
                    <a href="/" class="flex-shrink-0 flex items-center gap-3 text-xl font-bold text-white hover:opacity-80 transition">
                        <div class="bg-blue-600 p-2 rounded-lg">
                            <i class="fa-solid fa-graduation-cap text-white"></i>
                        </div>
                        CampusHub
                    </a>
                    <div class="hidden md:flex space-x-2">
                        <a href="/" class="text-gray-300 hover:text-white hover:bg-gray-700 px-3 py-2 rounded-md text-sm font-medium transition">Dashboard</a>
                        <a href="/absences" class="text-white bg-gray-900 px-3 py-2 rounded-md text-sm font-medium border border-gray-700 transition">Absences</a>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="hidden sm:flex flex-col items-end">
                        <span class="text-sm font-medium text-white"><%= typeof etudiant !== 'undefined' ? etudiant.prenom + ' ' + etudiant.nom : 'Student Name' %></span>
                        <span class="text-xs text-blue-400">ID: <%= typeof etudiant !== 'undefined' && etudiant.numero_inscription ? etudiant.numero_inscription : '12345678' %></span>
                    </div>
                    <img class="h-10 w-10 rounded-full border-2 border-gray-600 object-cover" 
                         src="<%= typeof etudiant !== 'undefined' && etudiant.profilePicture ? etudiant.profilePicture : '/uploads/default-avatars/default.png' %>" 
                         alt="Profile Picture">
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8 w-full">
        
        <header>
            <div class="flex items-center gap-2 text-sm text-gray-400 mb-2">
                <a href="/" class="hover:text-blue-400 transition">Home</a>
                <i class="fa-solid fa-chevron-right text-xs"></i>
                <span class="text-gray-200">Absence Tracking</span>
            </div>
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <h1 class="text-3xl font-bold text-white">Absence Tracking</h1>
                <a href="/attestation" class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-white px-4 py-2 rounded-lg transition shadow-sm text-sm font-medium">
                    <i class="fa-solid fa-download"></i> Get Attestation
                </a>
            </div>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-lg flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-400 font-medium">Total Absences</p>
                    <p class="text-3xl font-bold text-white mt-1">12 <span class="text-sm font-normal text-gray-500">hours</span></p>
                </div>
                <div class="h-12 w-12 rounded-full bg-blue-900/50 flex items-center justify-center border border-blue-800">
                    <i class="fa-solid fa-clock text-blue-400 text-xl"></i>
                </div>
            </div>

            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-lg flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-400 font-medium">Justified</p>
                    <p class="text-3xl font-bold text-green-400 mt-1">8 <span class="text-sm font-normal text-gray-500">hours</span></p>
                </div>
                <div class="h-12 w-12 rounded-full bg-green-900/50 flex items-center justify-center border border-green-800">
                    <i class="fa-solid fa-check-circle text-green-400 text-xl"></i>
                </div>
            </div>

            <div class="bg-gray-800 rounded-xl p-6 border border-red-900/50 shadow-lg flex items-center justify-between relative overflow-hidden">
                <div class="absolute right-0 top-0 w-2 h-full bg-red-500"></div>
                <div>
                    <p class="text-sm text-gray-400 font-medium">Unjustified</p>
                    <p class="text-3xl font-bold text-red-400 mt-1">4 <span class="text-sm font-normal text-gray-500">hours</span></p>
                </div>
                <div class="h-12 w-12 rounded-full bg-red-900/50 flex items-center justify-center border border-red-800">
                    <i class="fa-solid fa-triangle-exclamation text-red-400 text-xl"></i>
                </div>
            </div>
        </section>

        <section class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg overflow-hidden">
            
            <div class="p-6 border-b border-gray-700 bg-gray-800 flex flex-col md:flex-row gap-4 justify-between items-center">
                <h2 class="text-lg font-semibold text-white">Absence History</h2>
                
                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                            <i class="fa-solid fa-book text-gray-400 text-sm"></i>
                        </div>
                        <select class="bg-gray-900 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 p-2.5 appearance-none">
                            <option selected>All Subjects</option>
                            <option value="math">Mathematics</option>
                            <option value="physics">Physics</option>
                            <option value="cs">Computer Science</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400 text-xs"></i>
                        </div>
                    </div>

                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                            <i class="fa-solid fa-chalkboard-user text-gray-400 text-sm"></i>
                        </div>
                        <select class="bg-gray-900 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 p-2.5 appearance-none">
                            <option selected>All Teachers</option>
                            <option value="t1">Dr. Smith</option>
                            <option value="t2">Prof. Johnson</option>
                            <option value="t3">Mr. Anderson</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400 text-xs"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-400">
                    <thead class="text-xs text-gray-300 uppercase bg-gray-900 border-b border-gray-700">
                        <tr>
                            <th scope="col" class="px-6 py-4">Date & Time</th>
                            <th scope="col" class="px-6 py-4">Subject</th>
                            <th scope="col" class="px-6 py-4">Teacher</th>
                            <th scope="col" class="px-6 py-4">Type</th>
                            <th scope="col" class="px-6 py-4">Status</th>
                            <th scope="col" class="px-6 py-4 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-700">
                        
                        <tr class="bg-gray-800 hover:bg-gray-750 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-white font-medium">Oct 12, 2023</div>
                                <div class="text-xs text-gray-500">08:30 AM - 10:00 AM</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full bg-purple-500"></div>
                                    Mathematics (Analysis)
                                </div>
                            </td>
                            <td class="px-6 py-4">Dr. Smith</td>
                            <td class="px-6 py-4">Lecture (Cours)</td>
                            <td class="px-6 py-4">
                                <span class="bg-red-900/50 text-red-400 text-xs font-medium px-2.5 py-1 rounded border border-red-800">
                                    Unjustified
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button class="text-blue-400 hover:text-blue-300 font-medium text-xs underline">Justify</button>
                            </td>
                        </tr>

                        <tr class="bg-gray-800 hover:bg-gray-750 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-white font-medium">Oct 05, 2023</div>
                                <div class="text-xs text-gray-500">14:00 PM - 16:00 PM</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                                    Computer Science (Algo)
                                </div>
                            </td>
                            <td class="px-6 py-4">Prof. Johnson</td>
                            <td class="px-6 py-4">Lab (TP)</td>
                            <td class="px-6 py-4">
                                <span class="bg-green-900/50 text-green-400 text-xs font-medium px-2.5 py-1 rounded border border-green-800 flex inline-flex items-center gap-1">
                                    <i class="fa-solid fa-check text-[10px]"></i> Justified
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button class="text-gray-500 hover:text-white transition cursor-pointer" title="View Document">
                                    <i class="fa-solid fa-paperclip"></i>
                                </button>
                            </td>
                        </tr>

                        <tr class="bg-gray-800 hover:bg-gray-750 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-white font-medium">Sep 28, 2023</div>
                                <div class="text-xs text-gray-500">10:15 AM - 11:45 AM</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
                                    Physics (Mechanics)
                                </div>
                            </td>
                            <td class="px-6 py-4">Mr. Anderson</td>
                            <td class="px-6 py-4">Tutorial (TD)</td>
                            <td class="px-6 py-4">
                                <span class="bg-green-900/50 text-green-400 text-xs font-medium px-2.5 py-1 rounded border border-green-800 flex inline-flex items-center gap-1">
                                    <i class="fa-solid fa-check text-[10px]"></i> Justified
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button class="text-gray-500 hover:text-white transition cursor-pointer" title="View Document">
                                    <i class="fa-solid fa-paperclip"></i>
                                </button>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
            
            <div class="p-4 border-t border-gray-700 bg-gray-800 flex justify-between items-center text-sm text-gray-400">
                <span>Showing 1 to 3 of 3 entries</span>
                <div class="flex gap-2">
                    <button class="px-3 py-1 rounded bg-gray-900 border border-gray-700 hover:bg-gray-700 disabled:opacity-50" disabled>Prev</button>
                    <button class="px-3 py-1 rounded bg-gray-900 border border-gray-700 hover:bg-gray-700 disabled:opacity-50" disabled>Next</button>
                </div>
            </div>
        </section>

    </main>

</body>
</html>