<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CampusHub | My Profile</title>
    <link rel="icon" type="image/png" href="/logo_SS.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .chat-window {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateY(20px) scale(0.95);
            opacity: 0;
            pointer-events: none;
        }
        .chat-window.active {
            transform: translateY(0) scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4B5563; }
    </style>
</head>
<body class="bg-gray-900 min-h-screen font-sans flex flex-col text-gray-200">

    <!-- Reusable Navbar -->
    <%- include('partials/navbar') %>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">

        <!-- Page Header -->
        <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-white">My Profile</h1>
                <p class="text-gray-400 mt-1">Manage your personal information and account settings</p>
            </div>
            <button class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium transition flex items-center gap-2 shadow-lg shadow-blue-900/20">
                <i class="fa-solid fa-floppy-disk"></i>
                Save Changes
            </button>
        </header>

        <!-- Two-column layout on larger screens -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- Left column - Profile Card -->
            <div class="lg:col-span-1 space-y-6">

                <!-- Profile Picture & Basic Info -->
                <section class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg p-6 text-center">
                    <div class="relative inline-block">
                        <img class="h-32 w-32 rounded-full object-cover border-4 border-blue-600/40 mx-auto shadow-xl"
                             src="<%= etudiant.profilePicture || '/uploads/default-avatars/default.png' %>"
                             alt="Profile Picture">
                        <label for="profile-pic-upload" class="absolute bottom-0 right-0 bg-blue-600 hover:bg-blue-700 text-white p-2 rounded-full cursor-pointer shadow-md transition">
                            <i class="fa-solid fa-camera text-sm"></i>
                            <input type="file" id="profile-pic-upload" class="hidden" accept="image/*">
                        </label>
                    </div>
                    <h2 class="text-2xl font-bold mt-4"><%= etudiant.firstName %> <%= etudiant.lastName %></h2>
                    <p class="text-gray-400 mt-1"><%= etudiant.email %></p>
                    <p class="text-sm text-blue-400 mt-1">Student ID: <%= etudiant.nationalId || etudiant.studentId || '—' %></p>
                </section>
                <section class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg p-6">
                    <h3 class="text-lg font-semibold mb-5 flex items-center gap-2">
                        <i class="fa-solid fa-chart-line text-blue-400"></i>
                        Academic Overview
                    </h3>
                    <div class="space-y-5 text-sm">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-300">Attendance Rate</span>
<span class="text-lg font-bold <%= parseFloat(etudiant.attendanceRate) >= 85 ? 'text-green-400' : 'text-red-400' %>">
    <%= (etudiant.attendanceRate && !isNaN(parseFloat(etudiant.attendanceRate))) ? parseFloat(etudiant.attendanceRate).toFixed(1) : '—' %> %
</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-300">Active Semester    </span>
                            <span class="text-white font-medium">
                                <%= etudiant.currentSemester || 'No active semester' %>
                            </span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-300">Member Since</span>
                            <span class="text-gray-400">
                                <%= new Date(etudiant.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %>
                            </span>
                        </div>
                    </div>
                </section>
                
            </div>

<div class="lg:col-span-2 space-y-6">

                <!-- Personal Information Form -->
                <form id="profile-form" action="/profile" method="POST" class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg overflow-hidden">
                    <div class="p-6 border-b border-gray-700">
                        <h3 class="text-lg font-semibold flex items-center gap-2">
                            <i class="fa-solid fa-user-edit text-blue-400"></i>
                            Personal Information
                        </h3>
                    </div>
                    <div class="p-6 space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">First Name</label>
                                <input name="firstName" type="text" value="<%= etudiant.firstName %>" required
                                       class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white focus:border-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">Last Name</label>
                                <input name="lastName" type="text" value="<%= etudiant.lastName %>" required
                                       class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white focus:border-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                                <input name="email" type="email" value="<%= etudiant.email %>" required
                                       class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white focus:border-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">National ID (non-editable)</label>
                                <input type="text" value="<%= etudiant.nationalId %>" readonly
                                       class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-gray-400 cursor-not-allowed">
                            </div>
                        </div>
                    </div>
                </form>

                <!-- Change Password -->
                <section class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg overflow-hidden">
                    <div class="p-6 border-b border-gray-700">
                        <h3 class="text-lg font-semibold flex items-center gap-2">
                            <i class="fa-solid fa-lock text-blue-400"></i>
                            Change Password
                        </h3>
                    </div>
                    <form action="/profile/password" method="POST" class="p-6 space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">Current Password</label>
                                <input name="currentPassword" type="password" required
                                       class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white focus:border-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-2">New Password</label>
                                <input name="newPassword" type="password" required minlength="8"
                                       class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white focus:border-blue-500">
                            </div>
                        </div>
                        <button type="submit"
                                class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-lg transition flex items-center gap-2">
                            <i class="fa-solid fa-key"></i>
                            Update Password
                        </button>
                    </form>
                </section>

            </div>
        </div>
    </main>

    <!-- Floating Chat Button & Window -->
    <%- include('partials/chat-widget') %>   
    <script>
    const chatWindow = document.getElementById('ai-chat-window');
    const toggleBtn  = document.getElementById('toggle-chat');
    const closeBtn   = document.getElementById('close-chat');
    const notificationPing = toggleBtn?.querySelector('.absolute.top-0');

    function toggleChat() {
        chatWindow.classList.toggle('active');
        // Hide notification dot forever after first open
        if (notificationPing) notificationPing.style.display = 'none';
    }

    if (toggleBtn) toggleBtn.addEventListener('click', toggleChat);
    if (closeBtn)  closeBtn.addEventListener('click', toggleChat);

    // Optional: close when clicking outside (nice UX)
    document.addEventListener('click', function(e) {
        if (!chatWindow.contains(e.target) && !toggleBtn.contains(e.target)) {
            chatWindow.classList.remove('active');
        }
    });
</script>
<script>
    // Handle profile form with AJAX
    document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);

        try {
            const res = await fetch('/profile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
                alert('Profile updated successfully!');
            } else {
                alert(result.error || 'Failed to update profile');
            }
        } catch (err) {
            alert('Network error');
        }
    });
</script>
</body>
</html>