<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CampusHub | Internship Submission</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #111827;
        }

        ::-webkit-scrollbar-thumb {
            background: #374151;
            border-radius: 4px;
        }

        .fade-in {
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body class="bg-gray-900 text-gray-200 min-h-screen">

<!-- NAVBAR -->

<nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-[100]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <div class="flex items-center space-x-8">
                <a href="/" class="flex-shrink-0 flex items-center gap-3 text-xl font-bold text-white">
                    <div class="bg-blue-600 p-2 rounded-lg">
                        <i class="fa-solid fa-graduation-cap text-white"></i>
                    </div>
                    CampusHub
                </a>
                <div class="hidden md:flex space-x-2">
                    <a href="/" class="text-white bg-gray-900 px-3 py-2 rounded-md text-sm font-medium border border-gray-700 transition">Home</a>
                    <a href="/about" class="text-gray-300 hover:text-white hover:bg-gray-700 px-3 py-2 rounded-md text-sm font-medium transition">
                        About CampusHub
                    </a>
                </div>
            </div>

            <div class="flex items-center gap-4 relative">

                    <div class="hidden sm:flex flex-col items-end">
                            <span class="text-sm font-medium text-white">
                                <%= user.lastName %> <%= user.firstName %>
                            </span>
                        <span class="text-xs text-blue-400">
                                ID: <%= user.nationalId ? user.nationalId : 'N/A' %>
                            </span>
                    </div>

                    <div class="relative">
                        <button id="user-menu-button" class="flex items-center gap-2 focus:outline-none group">
                            <img class="h-10 w-10 rounded-full object-cover border-2 border-gray-600 group-hover:border-blue-500 transition"
                                 src="<%= user.profilePicture ? user.profilePicture : '/uploads/default-avatars/default-avatar.png' %>"
                                 alt="Profile">

                        </button>


                    </div>

            </div>
        </div>
    </div>
</nav>

<!-- PAGE -->
<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- HEADER -->
    <div class="mb-10">
        <h1 class="text-4xl font-bold text-white">
            Internship Submission
        </h1>

        <p class="text-gray-400 mt-3 text-lg">
            Upload your internship completion document in PDF format.
            Our AI assistant will scan and analyze the document automatically.
        </p>
    </div>

    <!-- MAIN GRID -->
    <div class="grid lg:grid-cols-2 gap-8">

        <!-- LEFT SIDE -->
        <div class="bg-gray-800 border border-gray-700 rounded-2xl p-8 shadow-xl">

            <div class="flex items-center gap-3 mb-6">
                <div class="bg-blue-600/20 text-blue-400 p-3 rounded-xl">
                    <i class="fa-solid fa-file-pdf text-2xl"></i>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-white">
                        Upload PDF
                    </h2>

                    <p class="text-sm text-gray-400">
                        Internship certificate or report
                    </p>
                </div>
            </div>

            <!-- FORM -->
            <form id="internship-form"
                  enctype="multipart/form-data"
                  class="space-y-6">

                <!-- FILE DROP -->
                <label for="pdfFile"
                       class="border-2 border-dashed border-gray-600 hover:border-blue-500 transition-all rounded-2xl p-10 flex flex-col items-center justify-center text-center cursor-pointer bg-gray-900/50">

                    <div class="bg-gray-800 p-5 rounded-full mb-4">
                        <i class="fa-solid fa-cloud-arrow-up text-4xl text-blue-400"></i>
                    </div>

                    <h3 class="text-lg font-semibold text-white">
                        Click to upload your PDF
                    </h3>

                    <p class="text-sm text-gray-400 mt-2">
                        Only PDF files are accepted
                    </p>

                    <input
                            type="file"
                            id="pdfFile"
                            name="pdfFile"
                            accept="application/pdf"
                            class="hidden"
                            required>
                </label>

                <!-- FILE INFO -->
                <div id="file-info"
                     class="hidden bg-gray-900 border border-gray-700 rounded-xl p-4 fade-in">

                    <div class="flex items-center gap-3">
                        <i class="fa-solid fa-file-pdf text-red-400 text-2xl"></i>

                        <div class="flex-1 overflow-hidden">
                            <p id="file-name"
                               class="text-white font-medium truncate"></p>

                            <p id="file-size"
                               class="text-sm text-gray-400"></p>
                        </div>
                    </div>
                </div>

                <!-- SUBMIT BUTTON -->
                <button
                        type="submit"
                        id="submit-btn"
                        class="w-full bg-blue-600 hover:bg-blue-700 transition-all text-white font-semibold py-4 rounded-xl shadow-lg flex items-center justify-center gap-3">

                    <i class="fa-solid fa-paper-plane"></i>
                    Submit Internship Document
                </button>

            </form>

        </div>

        <!-- RIGHT SIDE -->
        <div class="bg-gray-800 border border-gray-700 rounded-2xl shadow-xl flex flex-col overflow-hidden">

            <!-- HEADER -->
            <div class="border-b border-gray-700 p-6 flex items-center gap-4">

                <div class="bg-green-500/20 text-green-400 p-3 rounded-xl">
                    <i class="fa-solid fa-robot text-2xl"></i>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-white">
                        AI Analysis
                    </h2>

                    <p class="text-sm text-gray-400">
                        Automated internship validation assistant
                    </p>
                </div>

            </div>

            <!-- CONTENT -->
            <div id="analysis-box"
                 class="flex-1 p-6 overflow-y-auto bg-gray-900/50 min-h-[450px]">

                <div class="h-full flex items-center justify-center text-center text-gray-500">

                    <div>
                        <i class="fa-solid fa-brain text-5xl mb-5 text-gray-700"></i>

                        <p class="text-lg">
                            AI analysis will appear here after submission
                        </p>
                    </div>

                </div>

            </div>

        </div>

    </div>

</main>

<script>

    const pdfInput = document.getElementById('pdfFile');
    const fileInfo = document.getElementById('file-info');
    const fileName = document.getElementById('file-name');
    const fileSize = document.getElementById('file-size');

    const form = document.getElementById('internship-form');
    const analysisBox = document.getElementById('analysis-box');
    const submitBtn = document.getElementById('submit-btn');

    // =========================
    // FILE DISPLAY
    // =========================
    pdfInput.addEventListener('change', () => {

        const file = pdfInput.files[0];

        if (!file) return;

        fileInfo.classList.remove('hidden');

        fileName.textContent = file.name;

        fileSize.textContent =
            (file.size / (1024 * 1024)).toFixed(2) + ' MB';
    });

    // =========================
    // FORM SUBMIT
    // =========================
    form.addEventListener('submit', async (e) => {

        e.preventDefault();

        const file = pdfInput.files[0];

        if (!file) return;

        const formData = new FormData();
        formData.append('pdfFile', file);

        // LOADING UI
        submitBtn.disabled = true;

        submitBtn.innerHTML = `
            <i class="fa-solid fa-spinner fa-spin"></i>
            Processing Internship Document...
        `;

        analysisBox.innerHTML = `
            <div class="flex flex-col items-center justify-center h-full text-center text-gray-300">
                <i class="fa-solid fa-spinner fa-spin text-5xl text-blue-400 mb-6"></i>

                <h3 class="text-2xl font-bold text-white mb-3">
                    AI is analyzing your document
                </h3>

                <p class="text-gray-400 max-w-md">
                    Extracting internship information, validating signatures,
                    and checking document completeness...
                </p>
            </div>
        `;

        try {

            const response = await fetch('/api/internships/analyze', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            analysisBox.innerHTML = `
                <div class="space-y-6 fade-in">

                    <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-5">
                        <div class="flex items-center gap-3 mb-3">
                            <i class="fa-solid fa-circle-check text-green-400 text-2xl"></i>

                            <h3 class="text-xl font-bold text-white">
                                Analysis Completed
                            </h3>
                        </div>

                        <p class="text-gray-300">
                            ${data.message || 'Document processed successfully.'}
                        </p>
                    </div>

                    <div class="bg-gray-800 border border-gray-700 rounded-xl p-5">

                        <h4 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-file-lines text-blue-400"></i>
                            AI Response
                        </h4>

                        <div class="text-gray-300 leading-relaxed whitespace-pre-line">
                            ${data.analysis || 'No analysis returned by the AI service.'}
                        </div>

                    </div>

                </div>
            `;

        } catch (err) {

            console.error(err);

            analysisBox.innerHTML = `
                <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-6 text-center fade-in">

                    <i class="fa-solid fa-triangle-exclamation text-red-400 text-5xl mb-5"></i>

                    <h3 class="text-2xl font-bold text-white mb-3">
                        Upload Failed
                    </h3>

                    <p class="text-gray-300">
                        Something went wrong while processing the internship document.
                        Please try again later.
                    </p>

                </div>
            `;

        } finally {

            submitBtn.disabled = false;

            submitBtn.innerHTML = `
                <i class="fa-solid fa-paper-plane"></i>
                Submit Internship Document
            `;
        }

    });

</script>

</body>
</html>