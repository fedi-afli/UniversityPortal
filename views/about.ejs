<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CampusHub | About</title>
    <link rel="icon" type="image/png" href="/logo_SS.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .chat-window {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateY(20px) scale(0.95);
            opacity: 0;
            pointer-events: none;
        }
        .chat-window.active {
            transform: translateY(0) scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4B5563; }
    </style>
</head>
<body class="bg-gray-900 min-h-screen font-sans flex flex-col text-gray-200">

    <%- include('partials/navbar') %>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-12">

        <!-- Hero Section -->
        <section class="text-center py-12">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
                Welcome to <span class="text-blue-400">CampusHub</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-3xl mx-auto">
                Your modern digital companion for university life at the Faculty of Sciences of Bizerte
            </p>
        </section>

        <!-- Mission & Vision -->
        <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-gray-800 rounded-2xl p-8 border border-gray-700 shadow-xl">
                <div class="w-16 h-16 bg-blue-900/40 rounded-xl flex items-center justify-center mb-6">
                    <i class="fa-solid fa-rocket text-3xl text-blue-400"></i>
                </div>
                <h2 class="text-2xl font-bold text-white mb-4">Our Mission</h2>
                <p class="text-gray-300 leading-relaxed">
                    To simplify student life by centralizing access to academic documents, attendance tracking, 
                    requests for certificates, and communication with the administration — all in one secure, 
                    fast and beautiful platform.
                </p>
            </div>

            <div class="bg-gray-800 rounded-2xl p-8 border border-gray-700 shadow-xl">
                <div class="w-16 h-16 bg-purple-900/40 rounded-xl flex items-center justify-center mb-6">
                    <i class="fa-solid fa-eye text-3xl text-purple-400"></i>
                </div>
                <h2 class="text-2xl font-bold text-white mb-4">Our Vision</h2>
                <p class="text-gray-300 leading-relaxed">
                    Become the reference digital portal for Tunisian university students — intuitive, reliable, 
                    and constantly evolving with the real needs of students and administrative staff.
                </p>
            </div>
        </div>

        <!-- Features Grid -->
        <section>
            <h3 class="text-2xl font-bold text-center mb-10">What You Can Do on CampusHub</h3>
            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-gray-800/70 rounded-xl p-6 border border-gray-700 hover:border-blue-600/50 transition-all group">
                    <div class="w-14 h-14 bg-blue-900/30 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-600/30 transition">
                        <i class="fa-solid fa-file-certificate text-2xl text-blue-400"></i>
                    </div>
                    <h4 class="text-lg font-semibold mb-2">Certificates & Attestations</h4>
                    <p class="text-gray-400 text-sm">Request and download official documents instantly</p>
                </div>

                <div class="bg-gray-800/70 rounded-xl p-6 border border-gray-700 hover:border-blue-600/50 transition-all group">
                    <div class="w-14 h-14 bg-green-900/30 rounded-lg flex items-center justify-center mb-4 group-hover:bg-green-600/30 transition">
                        <i class="fa-solid fa-clipboard-check text-2xl text-green-400"></i>
                    </div>
                    <h4 class="text-lg font-semibold mb-2">Attendance Tracking</h4>
                    <p class="text-gray-400 text-sm">Follow your presence and justifications in real time</p>
                </div>

                <div class="bg-gray-800/70 rounded-xl p-6 border border-gray-700 hover:border-blue-600/50 transition-all group">
                    <div class="w-14 h-14 bg-purple-900/30 rounded-lg flex items-center justify-center mb-4 group-hover:bg-purple-600/30 transition">
                        <i class="fa-solid fa-robot text-2xl text-purple-400"></i>
                    </div>
                    <h4 class="text-lg font-semibold mb-2">AI Assistant</h4>
                    <p class="text-gray-400 text-sm">Get instant help 24/7 for all your questions</p>
                </div>
            </div>
        </section>

        <!-- Team / Credits -->
        <section class="bg-gray-800 rounded-2xl p-8 border border-gray-700 text-center">
            <h3 class="text-2xl font-bold mb-6">Made with passion</h3>
            <p class="text-gray-300 max-w-2xl mx-auto mb-8">
                CampusHub is a student project developed with love for better university life.
                Built with Node.js, Express, MongoDB, Tailwind CSS and a lot of coffee.
            </p>
            <div class="flex justify-center gap-6 text-3xl text-gray-500">
                <a href="#" class="hover:text-blue-400 transition"><i class="fab fa-github"></i></a>
                <a href="#" class="hover:text-blue-400 transition"><i class="fab fa-linkedin"></i></a>
                <a href="#" class="hover:text-blue-400 transition"><i class="fas fa-envelope"></i></a>
            </div>
        </section>

    </main>

    <!-- Floating Chat Button & Window -->
    <%- include('partials/chat-widget') %>
<script>
    // Chat toggle logic (same as in main.ejs)
    const chatWindow = document.getElementById('ai-chat-window');
    const toggleBtn  = document.getElementById('toggle-chat');
    const closeBtn   = document.getElementById('close-chat');
    const notificationPing = toggleBtn?.querySelector('.absolute.top-0');

    function toggleChat() {
        chatWindow.classList.toggle('active');
        // Hide notification dot forever after first open
        if (notificationPing) notificationPing.style.display = 'none';
    }

    if (toggleBtn) toggleBtn.addEventListener('click', toggleChat);
    if (closeBtn)  closeBtn.addEventListener('click', toggleChat);

    // Optional: close when clicking outside (nice UX)
    document.addEventListener('click', function(e) {
        if (!chatWindow.contains(e.target) && !toggleBtn.contains(e.target)) {
            chatWindow.classList.remove('active');
        }
    });
</script>
</body>
</html>